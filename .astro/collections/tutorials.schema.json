{
  "$ref": "#/definitions/tutorials",
  "definitions": {
    "tutorials": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "level": {
          "type": "string",
          "enum": [
            "beginner",
            "intermediate",
            "advanced"
          ]
        },
        "order": {
          "type": "number"
        },
        "duration": {
          "type": "string"
        },
        "prerequisites": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "draft": {
          "type": "boolean",
          "default": false
        },
        "lang": {
          "type": "string",
          "enum": [
            "en",
            "zh"
          ],
          "default": "en"
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "description",
        "level",
        "order",
        "duration"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}