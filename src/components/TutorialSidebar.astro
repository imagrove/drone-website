---
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { defaultLang, ui } from '../i18n/ui';

// Detect language from URL
const pathParts = Astro.url.pathname.split('/').filter(Boolean);
let lang = defaultLang;

if (pathParts[0] === 'tutorials' && pathParts[1] && pathParts[1] in ui) {
  lang = pathParts[1] as keyof typeof ui;
} else if (pathParts[0] === 'zh') {
  lang = 'zh';
} else if (pathParts[0] === 'en') {
  lang = 'en';
}
const t = useTranslations(lang);

// Get current path to highlight active item
const currentPath = Astro.url.pathname;
const currentSlug = currentPath.replace('/tutorials/', '').replace(/\/$/, '');
const currentLevel = currentSlug.split('/')[1];

// Get all tutorials for this language
const allTutorials = await getCollection('tutorials', ({ data }) => {
  return data.draft !== true && data.lang === lang;
});

// Group by level
const levels = ['beginner', 'intermediate', 'advanced'] as const;
const tutorialsByLevel = levels.map(level => {
  const levelTutorials = allTutorials
    .filter(t => t.data.level === level)
    .sort((a, b) => a.data.order - b.data.order);
  return { level, tutorials: levelTutorials };
});

const levelLabels: Record<string, string> = {
  beginner: t('courses.beginner.title'),
  intermediate: t('courses.intermediate.title'),
  advanced: t('courses.advanced.title'),
};

// 默认所有级别都是收缩状态
const isExpanded = (level: string) => false;
---

<!-- Mobile Toggle Button -->
<button 
  class="sidebar-toggle mobile-only"
  aria-label="Toggle sidebar"
>
  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <line x1="3" y1="6" x2="21" y2="6"></line>
    <line x1="3" y1="12" x2="21" y2="12"></line>
    <line x1="3" y1="18" x2="21" y2="18"></line>
  </svg>
</button>

<!-- Overlay -->
<div class="sidebar-overlay mobile-only"></div>

<!-- Sidebar -->
<aside class="sidebar">
  <nav>
    {tutorialsByLevel.map(({ level, tutorials }) => (
      tutorials.length > 0 && (
        <div class="level-group" data-level={level} data-expanded={isExpanded(level)}>
          <button 
            class="level-toggle"
            onclick={`toggleLevel('${level}')`}
          >
            <span>{levelLabels[level]}</span>
            <span class="toggle-icon">{isExpanded(level) ? '▼' : '▶'}</span>
          </button>
          <ul class="tutorial-list">
            {tutorials.map((tutorial) => {
              const isActive = currentSlug === tutorial.slug;
              const orderNum = tutorial.data.order.toString().padStart(2, '0');
              // Ensure the link includes the language prefix
              const tutorialHref = tutorial.slug.startsWith(`${lang}/`) 
                ? `/tutorials/${tutorial.slug}` 
                : `/tutorials/${lang}/${tutorial.slug}`;
              return (
                <li>
                  <a
                    href={tutorialHref}
                    class={`tutorial-link ${isActive ? 'active' : ''}`}
                  >
                    {orderNum}. {tutorial.data.title}
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      )
    ))}
  </nav>
</aside>

<style>
  /* Desktop Sidebar */
  .sidebar {
    width: 280px;
    border-right: 1px solid var(--border);
    padding: 1.5rem 1.5rem 3rem 1.5rem;
    height: calc(100vh - 70px);
    overflow-y: auto;
    position: sticky;
    top: 70px;
    background: white;
    transition: transform 0.3s ease;
  }

  /* Level Groups */
  .level-group {
    margin-bottom: 0.5rem;
  }

  .level-group:last-child {
    margin-bottom: 100px;
  }

  .level-toggle {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0.75rem;
    background: transparent;
    border: none;
    cursor: pointer;
    font-size: 0.85rem;
    text-transform: uppercase;
    color: var(--text-light);
    font-weight: 600;
    border-radius: var(--radius);
    min-height: 44px;
  }

  .level-toggle:hover {
    background: var(--bg-light);
  }

  .toggle-icon {
    transition: transform 0.2s;
  }

  /* Tutorial List */
  .tutorial-list {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 1rem 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
    max-height: 0;
  }

  .tutorial-list.expanded {
    max-height: 2000px;
  }

  .tutorial-link {
    display: block;
    padding: 0.75rem;
    border-radius: var(--radius);
    font-size: 0.9rem;
    color: var(--text-medium);
    background: transparent;
    font-weight: 400;
    text-decoration: none;
    min-height: 44px;
    line-height: 1.5;
    transition: all 0.2s;
  }

  .tutorial-link:hover {
    background: var(--bg-light);
    color: var(--primary);
  }

  .tutorial-link.active {
    color: var(--primary);
    background: var(--bg-light);
    font-weight: 600;
  }

  /* Mobile Styles */
  @media (max-width: 768px) {
    .mobile-only {
      display: block !important;
    }

    .sidebar-toggle {
      position: fixed;
      top: 80px;
      left: 1rem;
      z-index: 1001;
      background: white;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 0.75rem;
      cursor: pointer;
      box-shadow: var(--shadow);
      min-width: 44px;
      min-height: 44px;
    }

    .sidebar-overlay {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.5);
      z-index: 1000;
      opacity: 0;
      visibility: hidden;
      transition: all 0.3s ease;
    }

    .sidebar-overlay.active {
      opacity: 1;
      visibility: visible;
    }

    .sidebar {
      position: fixed;
      top: 0;
      left: -100%;
      width: 80%;
      max-width: 320px;
      height: 100vh;
      z-index: 1001;
      transform: translateX(0);
    }

    .sidebar.active {
      left: 0;
    }
  }

  @media (min-width: 769px) {
    .mobile-only {
      display: none !important;
    }
  }
</style>

<script is:inline>
  window.toggleLevel = function(level) {
    const group = document.querySelector('[data-level="' + level + '"]');
    if (group) {
      const isExpanded = group.getAttribute('data-expanded') === 'true';
      const list = group.querySelector('.tutorial-list');
      const icon = group.querySelector('.toggle-icon');
      
      if (isExpanded) {
        group.setAttribute('data-expanded', 'false');
        if (list) list.classList.remove('expanded');
        if (icon) icon.textContent = '▶';
        // 保存状态到 localStorage
        localStorage.setItem('sidebar-level-' + level, 'collapsed');
      } else {
        group.setAttribute('data-expanded', 'true');
        if (list) list.classList.add('expanded');
        if (icon) icon.textContent = '▼';
        // 保存状态到 localStorage
        localStorage.setItem('sidebar-level-' + level, 'expanded');
      }
    }
  };

  (function() {
    // 恢复侧边栏展开状态
    const levels = ['beginner', 'intermediate', 'advanced'];
    levels.forEach(function(level) {
      const savedState = localStorage.getItem('sidebar-level-' + level);
      const group = document.querySelector('[data-level="' + level + '"]');
      if (group && savedState) {
        const list = group.querySelector('.tutorial-list');
        const icon = group.querySelector('.toggle-icon');
        
        if (savedState === 'expanded') {
          group.setAttribute('data-expanded', 'true');
          if (list) list.classList.add('expanded');
          if (icon) icon.textContent = '▼';
        } else {
          group.setAttribute('data-expanded', 'false');
          if (list) list.classList.remove('expanded');
          if (icon) icon.textContent = '▶';
        }
      }
    });

    const toggleBtn = document.querySelector('.sidebar-toggle');
    const sidebar = document.querySelector('.sidebar');
    const overlay = document.querySelector('.sidebar-overlay');
    
    if (toggleBtn && sidebar && overlay) {
      toggleBtn.addEventListener('click', function() {
        sidebar.classList.toggle('active');
        overlay.classList.toggle('active');
        document.body.style.overflow = sidebar.classList.contains('active') ? 'hidden' : '';
      });
      
      overlay.addEventListener('click', function() {
        sidebar.classList.remove('active');
        overlay.classList.remove('active');
        document.body.style.overflow = '';
      });
    }
  })();
</script>
