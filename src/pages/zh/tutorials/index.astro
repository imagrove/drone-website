---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';

const tutorials = await getCollection('tutorials', ({ data }) => {
  return data.draft !== true && data.lang === 'zh';
});

tutorials.sort((a, b) => a.data.order - b.data.order);
---

<Layout 
    title="无人机教程 - 学习构建和编程 ESP32 无人机"
    description="从入门到精通的无人机教程。学习无人机组装、编程、飞行控制和 AI 集成。"
    lang="zh"
>
    <header style="background: white; border-bottom: 1px solid var(--border); padding: 1rem 2rem;">
        <nav style="max-width: 1200px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center;">
            <a href="/zh/" style="font-weight: 700; font-size: 1.25rem; color: var(--text-dark);">ESP32 Drone</a>
            <div style="display: flex; gap: 2rem;">
                <a href="/zh/">首页</a>
                <a href="/zh/tutorials" style="font-weight: 600;">教程</a>
                <a href="/zh/hardware">硬件</a>
                <a href="/zh/downloads">下载</a>
            </div>
            <div>
                <a href="/tutorials">EN</a>
            </div>
        </nav>
    </header>
    
    <main style="max-width: 1200px; margin: 0 auto; padding: 2rem; display: grid; grid-template-columns: 250px 1fr; gap: 2rem;">
        <!-- Sidebar -->
        <aside style="border-right: 1px solid var(--border); padding-right: 1rem;">
            <h3 style="margin-bottom: 1rem; font-size: 0.9rem; text-transform: uppercase; color: var(--text-light);">课程级别</h3>
            <nav style="display: flex; flex-direction: column; gap: 0.5rem;">
                <a href="/zh/tutorials" style="font-size: 0.9rem; font-weight: 600; color: var(--primary);">初级：飞行小能手</a>
                <a href="/zh/tutorials/intermediate" style="font-size: 0.9rem; color: var(--text-medium);">中级：飞行工程师</a>
                <a href="/zh/tutorials/advanced" style="font-size: 0.9rem; color: var(--text-medium);">高级：飞行科学家</a>
            </nav>
        </aside>
        
        <!-- Content -->
        <div>
            <h1 style="margin-bottom: 2rem;">教程</h1>
            
            <h2 style="margin-bottom: 1.5rem;">初级教程</h2>
            
            {tutorials.length > 0 ? (
                <div style="display: grid; gap: 1rem;">
                    {tutorials.map((tutorial) => (
                        <article style="background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem;">
                            <h2 style="margin-bottom: 0.5rem;">
                                <a href={`/zh/tutorials/${tutorial.slug}`} style="color: var(--text-dark);">
                                    {tutorial.data.title}
                                </a>
                            </h2>
                            <p style="color: var(--text-medium); margin-bottom: 1rem;">{tutorial.data.description}</p>
                            <div style="display: flex; gap: 1rem; font-size: 0.85rem; color: var(--text-light);">
                                <span>难度: {tutorial.data.level === 'beginner' ? '初级' : tutorial.data.level === 'intermediate' ? '中级' : '高级'}</span>
                                <span>时长: {tutorial.data.duration}</span>
                            </div>
                        </article>
                    ))}
                </div>
            ) : (
                <div style="background: #F3F4F6; border-radius: var(--radius); padding: 2rem; text-align: center;">
                    <p style="color: var(--text-medium); margin-bottom: 1rem;">中文教程内容正在准备中...</p>
                    <p style="font-size: 0.9rem;">请先查看 <a href="/tutorials">英文教程</a> 或 <a href="/zh/tutorials/intermediate">中级教程</a></p>
                </div>
            )}
        </div>
    </main>
</Layout>
