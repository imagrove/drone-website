---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const tutorials = await getCollection('tutorials');
  return tutorials.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout 
    title={`${entry.data.title} - ESP32 Drone Tutorial`}
    description={entry.data.description}
    lang="en"
>
    <header style="background: white; border-bottom: 1px solid var(--border); padding: 1rem 2rem;">
        <nav style="max-width: 1200px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center;">
            <a href="/" style="font-weight: 700; font-size: 1.25rem; color: var(--text-dark);">ESP32 Drone</a>
            <div style="display: flex; gap: 2rem;">
                <a href="/">Home</a>
                <a href="/tutorials">Tutorials</a>
                <a href="/hardware">Hardware</a>
                <a href="/downloads">Downloads</a>
            </div>
        </nav>
    </header>
    
    <div style="max-width: 1200px; margin: 0 auto; padding: 2rem; display: grid; grid-template-columns: 250px 1fr; gap: 2rem;">
        <!-- Sidebar -->
        <aside style="border-right: 1px solid var(--border); padding-right: 1rem;">
            <h3 style="margin-bottom: 1rem; font-size: 0.9rem; text-transform: uppercase; color: var(--text-light);">
                Beginner Tutorial
            </h3>
            <nav style="display: flex; flex-direction: column; gap: 0.5rem;">
                <a href="#overview" style="font-size: 0.9rem;">Overview</a>
                <a href="#materials" style="font-size: 0.9rem;">Materials</a>
                <a href="#assembly" style="font-size: 0.9rem;">Assembly</a>
                <a href="#firmware" style="font-size: 0.9rem;">Firmware</a>
                <a href="#first-flight" style="font-size: 0.9rem;">First Flight</a>
            </nav>
        </aside>
        
        <!-- Content -->
        <main>
            <div style="margin-bottom: 2rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border);">
                <span style="font-size: 0.85rem; color: var(--text-light); text-transform: uppercase;">
                    {entry.data.level} Level
                </span>
                <h1 style="margin: 0.5rem 0;">{entry.data.title}</h1>
                <p style="color: var(--text-medium);">{entry.data.description}</p>
                <div style="display: flex; gap: 1rem; margin-top: 1rem; font-size: 0.85rem; color: var(--text-light);">
                    <span>Duration: {entry.data.duration}</span>
                    {entry.data.prerequisites && (
                        <span>Prerequisites: {entry.data.prerequisites.join(', ')}</span>
                    )}
                </div>
            </div>
            
            <article style="line-height: 1.8;">
                <Content />
            </article>
        </main>
    </div>
</Layout>
